# Parchment v0.1 env. Copy to .env and adjust.

# Postgres (single-container: this points at the bundled instance)
DATABASE_URL=postgres://parchment:parchment@localhost:5432/parchment

# Collab (Hocuspocus) — same container, separate process
COLLAB_PORT=1234
COLLAB_URL=ws://localhost:1234

# Disk mirror root (Plan F)
PARCHMENT_FILES_ROOT=/data/parchment/files

# Secure cookies (CF1). The session cookie is sent `Secure` (https-only) when
# NODE_ENV=production. If you serve Parchment over https behind a reverse proxy
# (Caddy/nginx) but the container does NOT set NODE_ENV=production, set this to
# `true` so the browser keeps the session cookie. Leave UNSET for plain http
# (local dev) — a Secure cookie is dropped over http and login/theme-save fail.
# SECURE_COOKIES=true

# AI compose sleeve (Plan G13) — optional. If set, no-key fallback to Ollama.
# OLLAMA_URL=http://homelab:11434
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Grammar check via LanguageTool (Plan K7) — OFF by default. Set LANGUAGETOOL_URL
# to a self-hosted or cloud LanguageTool instance to enable the grammar action;
# leaving it unset means NO external call is made and the grammar endpoint 404s.
# The check is proxied server-side, so the optional API key NEVER reaches the
# browser. (e.g. a local docker run -p 8010:8010 erikvl87/languagetool)
# LANGUAGETOOL_URL=http://localhost:8010
# LANGUAGETOOL_API_KEY=
# LANGUAGETOOL_USERNAME=

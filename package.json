{
  "name": "parchment",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "collab": "tsx collab/server.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0",
    "@hocuspocus/server": "4.3.0",
    "@hocuspocus/extension-database": "4.3.0",
    "yjs": "13.6.31",
    "y-protocols": "1.0.7",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/pg": "8.20.0",
    "@biomejs/biome": "2.5.0",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.3.1",
    "@tailwindcss/postcss": "4.3.1",
    "tsx": "4.22.4"
  }
}
